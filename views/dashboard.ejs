<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SIRIUS INC - Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-100">
  <div class="max-w-7xl mx-auto p-6">
    <div class="flex justify-between items-center mb-10">
      <div>
        <h1 class="text-4xl font-bold text-gray-900">SIRIUS INC Dashboard</h1>
        <p class="text-gray-600">House Hunting Management</p>
      </div>
      <a href="/" target="_blank" class="bg-white px-6 py-3 rounded-full shadow hover:bg-gray-50 font-medium">
        👀 View Live Website
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Add New Property with File Upload -->
      <div class="lg:col-span-1 bg-white p-8 rounded-3xl shadow">
        <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
          <i class="fas fa-plus"></i> Add New Property
        </h2>
        <form action="/add-property" method="POST" enctype="multipart/form-data" class="space-y-5">
          <input type="text" name="title" placeholder="Property Title" required class="w-full p-4 border rounded-2xl">
          <input type="number" name="price" placeholder="Price (KSh)" required class="w-full p-4 border rounded-2xl">
          <input type="text" name="type" placeholder="Bedsitter, 1BR, 2BR..." required class="w-full p-4 border rounded-2xl">
          <input type="text" name="location" placeholder="Location" required class="w-full p-4 border rounded-2xl">
          
          <!-- File Upload -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Property Photo</label>
            <input type="file" name="image" accept="image/*" class="w-full p-4 border rounded-2xl bg-gray-50">
            <p class="text-xs text-gray-500 mt-1">You can also paste Image URL below (optional)</p>
          </div>
          
          <input type="text" name="image" placeholder="Or Image URL (optional)" class="w-full p-4 border rounded-2xl">
          
          <textarea name="description" placeholder="Description" rows="3" class="w-full p-4 border rounded-2xl"></textarea>
          
          <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-600 text-black py-4 rounded-2xl font-bold">
            Add Property
          </button>
        </form>
      </div>

      <!-- Statistics -->
      <div class="lg:col-span-2 grid grid-cols-2 gap-6">
        <div class="bg-white p-8 rounded-3xl shadow text-center">
          <h3 class="text-4xl font-bold text-yellow-600"><%= data.properties ? data.properties.length : 0 %></h3>
          <p class="text-gray-600 mt-2">Total Properties</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow text-center">
          <h3 class="text-4xl font-bold text-green-600"><%= data.requests ? data.requests.length : 0 %></h3>
          <p class="text-gray-600 mt-2">Customer Inquiries</p>
        </div>
      </div>
    </div>

    <!-- Customer Inquiries -->
    <div class="mt-12">
      <h2 class="text-2xl font-semibold mb-6">📩 Customer Inquiries</h2>
      <% if (data.requests && data.requests.length > 0) { %>
        <div class="space-y-6">
          <% data.requests.slice().reverse().forEach(req => { %>
            <div class="bg-white p-6 rounded-3xl shadow">
              <div class="flex justify-between items-start">
                <div>
                  <strong class="text-lg"><%= req.name %></strong> 
                  <span class="text-gray-500">• <%= req.phone %></span>
                </div>
                <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full"><%= req.date %></span>
              </div>
              <p class="mt-2 font-medium"><%= req.type %></p>
              <p class="text-gray-600 mt-3"><%= req.message %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-gray-500 bg-white p-12 rounded-3xl text-center">No inquiries yet. They will appear here when clients submit requests.</p>
      <% } %>
    </div>

    <!-- Properties -->
    <div class="mt-12">
      <h2 class="text-2xl font-semibold mb-6">🏠 Properties (<%= data.properties ? data.properties.length : 0 %>)</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (data.properties && data.properties.length > 0) { %>
          <% data.properties.slice().reverse().forEach(property => { %>
            <div class="bg-white rounded-3xl shadow overflow-hidden">
              <img src="<%= property.image || 'https://picsum.photos/id/1015/600/400' %>" 
                   class="w-full h-48 object-cover" alt="<%= property.title %>">
              <div class="p-5">
                <h3 class="font-bold"><%= property.title %></h3>
                <p class="text-2xl font-semibold text-yellow-600">KSh <%= property.price %></p>
                <p class="text-sm text-gray-500"><%= property.type %> • <%= property.location %></p>
                <form action="/delete-property" method="POST" class="mt-4">
                  <input type="hidden" name="id" value="<%= property.id %>">
                  <button type="submit" class="text-red-600 hover:text-red-700 text-sm">🗑 Delete</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="col-span-3 text-center text-gray-500 py-20">No properties added yet. Add your first one above.</p>
        <% } %>
      </div>
    </div>

    <!-- Video Section -->
    <div class="mt-12 bg-white p-8 rounded-3xl shadow">
      <h2 class="text-2xl font-semibold mb-6">🎥 Property Videos</h2>
      <p class="text-gray-600 mb-6">Video upload support coming soon. For now, you can add video links manually in the website code.</p>
      <div class="bg-gray-100 border-2 border-dashed border-gray-300 rounded-3xl p-12 text-center">
        <p class="text-gray-500">🎬 Video Management Coming Soon</p>
      </div>
    </div>
  </div>
</body>
</html>